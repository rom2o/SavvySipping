# ─── Anthropic ───────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── Adobe PDF Services ──────────────────────────────────────
# Path to your pdfservices-api-credentials.json file
ADOBE_CREDENTIALS_PATH=pdfservices-api-credentials.json

# ─── Flask ───────────────────────────────────────────────────
FLASK_SECRET_KEY=change-this-to-a-random-secret
FLASK_DEBUG=False

# ─── Email (SendGrid) ────────────────────────────────────────
# Optional – leave blank to skip email delivery
SENDGRID_API_KEY=
FROM_EMAIL=noreply@yourapp.com
